{
  "openapi": "3.0.4",
  "info": {
    "title": "Blood Bridge API",
    "description": "An intelligent platform for blood donation coordination using AI and GPS.",
    "version": "v1"
  },
  "paths": {
    "/api/Auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registers a new user (Donor, Recipient, or Hospital).",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Authenticates a user and returns a JWT token.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Donors/match/{requestId}": {
      "get": {
        "tags": [
          "Donors"
        ],
        "summary": "Gets a prioritized list of donors based on proximity and reliability.",
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Donors/respond": {
      "post": {
        "tags": [
          "Donors"
        ],
        "summary": "Records the donor's response to an emergency alert.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { }
            },
            "text/json": {
              "schema": { }
            },
            "application/*+json": {
              "schema": { }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Donors/leaderboard": {
      "get": {
        "tags": [
          "Donors"
        ],
        "summary": "Returns the top-ranked donors for the leaderboard.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Hospitals/confirm-donation/{id}": {
      "put": {
        "tags": [
          "Hospitals"
        ],
        "summary": "Confirms a completed donation and updates the hospital's records.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Hospitals/inventory": {
      "put": {
        "tags": [
          "Hospitals"
        ],
        "summary": "Updates the hospital blood inventory levels.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Notifications": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "summary": "Gets all alerts for the logged-in user (Emergency or Matching).",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/submit": {
      "post": {
        "tags": [
          "Requests"
        ],
        "summary": "Submits a blood request and triggers AI for blood type extraction.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BloodRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BloodRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BloodRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/{id}/status": {
      "get": {
        "tags": [
          "Requests"
        ],
        "summary": "Tracks the real-time status of a specific request.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/{id}/emergency-trigger": {
      "post": {
        "tags": [
          "Requests"
        ],
        "summary": "Manually triggers an emergency alert for an existing request, \r\nprioritizing it in the matching algorithm and sending urgent notifications.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/history": {
      "get": {
        "tags": [
          "Requests"
        ],
        "summary": "Fetches the history of all blood requests made by the authenticated user.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/confirm-detection": {
      "post": {
        "tags": [
          "Requests"
        ],
        "summary": "Confirms the AI-detected blood type before starting the search.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DonorResponseRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DonorResponseRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DonorResponseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Requests/{id}/cancel": {
      "delete": {
        "tags": [
          "Requests"
        ],
        "summary": "Cancels an active blood request and stops further donor matching or notifications.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the request to cancel.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/profile": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Retrieves the profile information for the authenticated user, \r\nincluding blood type, total points, and contact details.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/location": {
      "patch": {
        "tags": [
          "Users"
        ],
        "summary": "Updates the donor's current GPS coordinates. \r\nThis is critical for the AI Matching algorithm to calculate distance.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LocationUpdateRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LocationUpdateRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LocationUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/availability": {
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Updates user's availability status (Available/Unavailable) to receive donation requests.",
        "parameters": [
          {
            "name": "isAvailable",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/delete-account": {
      "delete": {
        "tags": [
          "Users"
        ],
        "summary": "Permanently deletes the user's account and all associated personal data from the system.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BloodRequestDto": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "integer",
            "format": "int32"
          },
          "medicalReportText": {
            "type": "string",
            "nullable": true
          },
          "bloodType": {
            "type": "string",
            "nullable": true
          },
          "quantity": {
            "type": "integer",
            "format": "int32"
          },
          "urgencyLevel": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "hospitalId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "DonorResponseRequest": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "integer",
            "format": "int32"
          },
          "isAccepted": {
            "type": "boolean"
          },
          "bloodType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LocationUpdateRequest": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserRegisterRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "bloodType": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          },
          "governorate": {
            "type": "string",
            "nullable": true
          },
          "donorRate": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      }
    }
  }
}